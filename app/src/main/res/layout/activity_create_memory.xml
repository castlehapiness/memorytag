<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070707"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="60dp">

        <!-- ── HEADER ────────────────────────────────────────────────────── -->

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/bg_button_back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:contentDescription="Retour"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/screenTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="24dp"
            android:text="Nouveau souvenir"
            android:textColor="#F2F2F2"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintTop_toTopOf="@id/backButton"
            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/screenSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="6dp"
            android:text="Il sera accessible via un tag NFC"
            android:textColor="#3A3A3A"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/backButton"/>

        <!-- ── FORMULAIRE ────────────────────────────────────────────────── -->

        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/screenSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ═══ TITRE (obligatoire) ══════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TITRE *"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/stroke_dark"
                app:boxBackgroundColor="@color/surface_dark"
                app:hintTextColor="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/titleInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ex: Week-end à Paris"
                    android:textColor="#F2F2F2"
                    android:textColorHint="#333333"
                    android:textSize="16sp"
                    android:inputType="textCapSentences"
                    android:maxLines="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ═══ LOCALISATION (obligatoire) ══════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCALISATION *"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/stroke_dark"
                app:boxBackgroundColor="@color/surface_dark"
                app:hintTextColor="@color/text_hint"
                app:startIconDrawable="@drawable/ic_location_pin"
                app:startIconTint="@color/accent_red">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/locationInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ex: Paris, France"
                    android:textColor="#F2F2F2"
                    android:textColorHint="#333333"
                    android:textSize="16sp"
                    android:inputType="textCapSentences"
                    android:maxLines="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ═══ DESCRIPTION (optionnel) ══════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/stroke_dark"
                app:boxBackgroundColor="@color/surface_dark"
                app:hintTextColor="@color/text_hint"
                app:counterEnabled="true"
                app:counterMaxLength="200"
                app:counterTextColor="@color/text_dim">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descriptionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Une courte description…"
                    android:textColor="#F2F2F2"
                    android:textColorHint="#333333"
                    android:textSize="15sp"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="2"
                    android:maxLines="4"
                    android:maxLength="200"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ═══ SÉPARATEUR OPTIONNEL ══════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1A1A1A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="DÉTAILS OPTIONNELS"
                    android:textColor="#2C2C2C"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1A1A1A"/>
            </LinearLayout>

            <!-- ═══ DATE (optionnel) ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/stroke_dark"
                app:boxBackgroundColor="@color/surface_dark"
                app:hintTextColor="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dateInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ex: Juin 2024"
                    android:textColor="#F2F2F2"
                    android:textColorHint="#333333"
                    android:textSize="15sp"
                    android:maxLines="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ═══ COORDONNÉES GPS (optionnel) ══════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COORDONNÉES GPS"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <!-- Latitude + Longitude côte à côte -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/stroke_dark"
                    app:boxBackgroundColor="@color/surface_dark"
                    app:hintTextColor="@color/text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/latitudeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Latitude"
                        android:textColor="#F2F2F2"
                        android:textColorHint="#333333"
                        android:textSize="14sp"
                        android:inputType="numberDecimal|numberSigned"
                        android:maxLines="1"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/stroke_dark"
                    app:boxBackgroundColor="@color/surface_dark"
                    app:hintTextColor="@color/text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/longitudeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Longitude"
                        android:textColor="#F2F2F2"
                        android:textColorHint="#333333"
                        android:textSize="14sp"
                        android:inputType="numberDecimal|numberSigned"
                        android:maxLines="1"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ex: 48.8566 / 2.3522 pour Paris"
                android:textColor="#2A2A2A"
                android:textSize="11sp"/>

            <!-- ═══ PHOTOS (optionnel) ════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTOS (URLs)"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/stroke_dark"
                app:boxBackgroundColor="@color/surface_dark"
                app:hintTextColor="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/photosInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://... (une URL par ligne)"
                    android:textColor="#F2F2F2"
                    android:textColorHint="#333333"
                    android:textSize="13sp"
                    android:inputType="textMultiLine|textUri"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="URLs https:// séparées par des retours à la ligne"
                android:textColor="#2A2A2A"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- ── BOUTON CRÉER ──────────────────────────────────────────────── -->

        <FrameLayout
            android:id="@+id/buttonContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/formContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Créer le souvenir"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="@color/button_red"
                app:cornerRadius="14dp"
                app:rippleColor="@color/ripple_white"/>

            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="#FFFFFF"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- ── BLOC ID CRÉÉ + PROMPT NFC ────────────────────────────────── -->

        <LinearLayout
            android:id="@+id/createdIdContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="28dp"
            android:padding="20dp"
            android:background="@drawable/bg_id_card"
            android:visibility="gone"
            android:alpha="0"
            app:layout_constraintTop_toBottomOf="@id/buttonContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID DU SOUVENIR"
                android:textColor="#3A3A3A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/createdIdText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F2F2F2"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"/>

            <TextView
                android:id="@+id/nfcWritePrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Étape 2 : Programmer le tag NFC"
                android:textColor="#F2F2F2"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/nfcWriteStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#888888"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
