<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal du souvenir.
    Design immersif : fond noir, photo plein-largeur,
    galerie horizontale, globe, textes épurés.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- ═══════════════════════════════════════════
         SCROLL PRINCIPAL
         ═══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:alpha="0">

            <!-- ═══════════════════════════════════════
                 PHOTO PRINCIPALE — Plein largeur 4:3
                 ═══════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/mainPhotoImage"
                    android:layout_width="match_parent"
                    android:layout_height="420dp"
                    android:scaleType="centerCrop"
                    android:background="#111111"/>

                <!-- Dégradé bas de la photo pour lisibilité -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_photo_bottom"/>

            </FrameLayout>

            <!-- ═══════════════════════════════════════
                 GALERIE MINIATURES (RecyclerView horizontal)
                 ═══════════════════════════════════════ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/galleryRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:scrollbars="none"/>

            <!-- ═══════════════════════════════════════
                 INFOS : TITRE + LOCALISATION + DATE
                 ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp">

                <!-- Titre principal -->
                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.1"/>

                <!-- Localisation avec icône pin -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_pin"
                        android:tint="#FF3B30"/>

                    <TextView
                        android:id="@+id/locationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="#FF3B30"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <!-- Date -->
                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/descriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════
                 SÉPARATEUR SUBTIL
                 ═══════════════════════════════════════ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="#1AFFFFFF"/>

            <!-- ═══════════════════════════════════════
                 GLOBE SECTION
                 ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="60dp">

                <!-- Label section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCALISATION"
                    android:textColor="#404040"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp"/>

                <!-- Globe custom view -->
                <com.memorytag.app.ui.view.GlobeView
                    android:id="@+id/globeView"
                    android:layout_width="200dp"
                    android:layout_height="200dp"/>

                <!-- Nom de ville sous le globe -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/globeLocationLabel"
                    android:layout_marginTop="20dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.03"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════
         BOUTON RETOUR — flottant en haut à gauche
         ═══════════════════════════════════════════ -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        android:padding="8dp"
        android:background="@drawable/bg_button_back"
        android:src="@drawable/ic_arrow_back"
        android:tint="#FFFFFF"
        android:contentDescription="Retour"/>

    <!-- ═══════════════════════════════════════════
         OVERLAY DE CHARGEMENT
         ═══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC080808"
        android:visibility="gone"
        android:gravity="center">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFF"/>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
