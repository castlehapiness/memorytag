<?xml version="1.0" encoding="utf-8"?>
<!--
    Écran d'accueil : minimaliste, fond sombre, animation pulsation NFC.
    Design premium inspiré Apple / Instagram.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- Logo / Icône centrale NFC -->
    <LinearLayout
        android:id="@+id/idleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Animation ripple NFC -->
        <FrameLayout
            android:id="@+id/nfcRippleView"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center">

            <!-- Cercle externe animé -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/ripple_circle_outer"
                android:alpha="0.3"/>

            <!-- Cercle moyen -->
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/ripple_circle_mid"
                android:alpha="0.5"/>

            <!-- Cercle intérieur avec icône NFC -->
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:padding="16dp"
                android:background="@drawable/circle_white"
                android:src="@drawable/ic_nfc"
                android:tint="#080808"/>
        </FrameLayout>

        <!-- Texte principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Approchez votre tag"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.02"/>

        <!-- Sous-titre -->
        <TextView
            android:id="@+id/nfcStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Scannez un tag NFC pour revivre ce moment"
            android:textColor="#808080"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:gravity="center"/>

        <!-- Message d'erreur (caché par défaut) -->
        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:textColor="#FF3B30"
            android:textSize="13sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- État chargement (spinner + texte) -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Chargement du souvenir…"
            android:textColor="#808080"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Bouton debug (dev only — à masquer en prod) -->
    <TextView
        android:id="@+id/debugButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="[ Simuler un scan NFC ]"
        android:textColor="#404040"
        android:textSize="12sp"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
